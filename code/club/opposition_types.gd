class_name OppositionTypes
extends RefCounted

# Index-based values match OPPOSITION lookup table in FieldMappings
enum Opposition {
	NON_EXISTENT           = 0,  # NichtVorhanden
	AMATEURS_ONLY          = 1,  # NurStuemper
	FORMING                = 2,  # FormiertSich
	PRESENT                = 3,  # DurchausVorhanden
	COMPETITIVE            = 4,  # Konkurenzfaehig
	VERY_STRONG            = 5,  # SehrStark
	POWERFUL_AND_COMPETENT = 6,  # MaechtigUndKompetent
}
