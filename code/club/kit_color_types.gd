class_name KitColorTypes
extends RefCounted

# Index-based values match TRIKOT_FARBE lookup table in FieldMappings
enum KitColor {
	WHITE       = 0,   # Weiss
	RED         = 1,   # Rot
	YELLOW      = 2,   # Gelb
	BLUE        = 3,   # Blau
	LIGHT_GREEN = 4,   # Hellgruen
	GREEN       = 5,   # Gruen
	TURQUOISE   = 6,   # Tuerkis
	LIGHT_BLUE  = 7,   # Hellblau
	BROWN       = 8,   # Braun
	PURPLE      = 9,   # Lila
	ORANGE      = 10,  # Orange
	BLACK       = 11,  # Schwarz
	BURGUNDY    = 12,  # Weinrot
}
