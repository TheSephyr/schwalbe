class_name FanTypeTypes
extends RefCounted

# Index-based values match ART_DER_FANS lookup table in FieldMappings
enum FanType {
	NORMAL     = 0,  # Normal
	VOCAL      = 1,  # Lautstark
	SPOILED    = 2,  # Verwoehnt
	DEMANDING  = 3,  # Anspruchsvoll
	LOYAL      = 4,  # Treu
	AMBITIOUS  = 5,  # Erfolgshungrig
	FRUSTRATED = 6,  # Frustriert
	EUPHORIC   = 7,  # Euphorisch
}
