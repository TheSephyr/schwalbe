class_name HairColorTypes
extends RefCounted

# Index-based values match HAARFARBE lookup table in FieldMappings
enum HairColor {
	LIGHT_BLONDE = 0,  # Hellblond
	BLONDE       = 1,  # Blond
	BROWN        = 2,  # Braun
	RED          = 3,  # Rot
	BLACK        = 4,  # Schwarz
	BALD         = 5,  # Glatze
	GREY         = 6,  # Grau
}
