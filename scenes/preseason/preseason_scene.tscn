[node name="InputLabel" type="Label" parent="NegotiationPanel/NegMargin/NegVBox"]
layout_mode = 2
text = "Ihr Gegenangebot (DM):"
theme_override_font_sizes/font_size = 12

[node name="CounterInput" type="LineEdit" parent="NegotiationPanel/NegMargin/NegVBox"]
layout_mode = 2
placeholder_text = "z.B. 500000"
theme_override_font_sizes/font_size = 13

[node name="MakeOfferButton" type="Button" parent="NegotiationPanel/NegMargin/NegVBox"]
layout_mode = 2
