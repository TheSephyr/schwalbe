[connection signal="pressed" from="Content/OuterVBox/WeiterButton" to="." method="_on_weiter_pressed"]
[connection signal="pressed" from="NegotiationPanel/NegMargin/NegVBox/NegHeader/NegCloseButton" to="." method="_on_neg_close_pressed"]
[connection signal="pressed" from="NegotiationPanel/NegMargin/NegVBox/MakeOfferButton" to="." method="_on_make_offer_pressed"]
